{
    // === GLOBAL ===
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    },

    // === PYTHON / ROBOT ===
    "python.defaultInterpreterPath": "${workspaceFolder}/robot/venv/bin/python",
    "robot.language-server.python": "${workspaceFolder}/robot/venv/bin/python",
    "python.analysis.extraPaths": [
        "${workspaceFolder}/robot/venv/lib/python3.12/site-packages",
        "robot/resources",
        "robot/tests"
    ],
    "robot.variables": {},
    "robot.pythonpath": [
        "robot/resources",
        "robot/venv/bin/python",
        "robot/venv/lib/python3.12/site-packages"
    ],

    "[robotframework]": {
        "editor.defaultFormatter": "robocorp.robotframework-lsp",
        "editor.formatOnSave": true
    },

    // === JAVASCRIPT / TYPESCRIPT / CYPRESS ===
    "javascript.suggest.completeFunctionCalls": true,
    "typescript.suggest.completeFunctionCalls": true,
    "eslint.workingDirectories": ["cypress"],
    "eslint.validate": [
        "javascript",
        "typescript",
        "javascriptreact",
        "typescriptreact"
    ],
    "[javascript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    },
    "[typescript]": {
        "editor.defaultFormatter": "dbaeumer.vscode-eslint"
    }
}
